{
  "app": {
    "title": "Consolidação de dados de Perfuração para Desmonte - Planejado/Executado",
    "description": "Processamento client-side para consolidar MVV.xlsx e RD.txt"
  },
  "files": {
    "mvv": {
      "accept": ".xlsx"
    },
    "rd": {
      "accept": ".txt"
    },
    "pitdev_field": {
      "accept": ".csv,.txt"
    },
    "pitdev_plan": {
      "accept": ".xlsx"
    }
  },
  "input": {
    "mvv_sheet_name": "PROJETO PERFURAÇÃO",
    "mvv_header_row": 1,
    "rd_delimiter": ",",
    "rd_expected_fields": 5,
    "pitdev_field_delimiter": ",",
    "pitdev_field_allowed_field_counts": [4, 5],
    "pitdev_field_trailing_empty_fields": 1,
    "pitdev_plan_sheet_name": "PROJETO PERFURAÇÃO",
    "pitdev_plan_header_row": 1
  },
  "columns": {
    "mvv": [
      "ID",
      "Type",
      "Descricao",
      "Diameter",
      "X Collar",
      "Y Collar",
      "X Toe",
      "Y Toe",
      "Z Toe",
      "Z Collar",
      "Depth",
      "Sub Drill",
      "Azimuth",
      "Dip"
    ],
    "rd_only": [
      "ID",
      "Y",
      "X",
      "Z",
      "Profundidade"
    ],
    "rd_treated": [
      "ID_RD",
      "Y_RD",
      "X_RD",
      "Z_RD",
      "TIPO_RD"
    ],
    "consolidated": [
      "ID",
      "Type",
      "Descricao",
      "Diameter",
      "X Collar",
      "Y Collar",
      "X Toe",
      "Y Toe",
      "Z Toe",
      "Z Collar",
      "Depth",
      "Sub Drill",
      "Azimuth",
      "Dip",
      "ID_RD",
      "TIPO_RD",
      "Y_RD",
      "X_RD",
      "Z_RD",
      "ID_FINAL",
      "Y_FINAL",
      "X_FINAL",
      "Z_COLLAR_FINAL",
      "PROFUNDIDADE_FINAL",
      "Diâmetro",
      "Azimute",
      "Ângulo planejado",
      "Ângulo do talude"
    ],
    "mvv_plan": [
      "ID",
      "Type",
      "Explosivo",
      "Diameter",
      "X Collar",
      "Y Collar",
      "Z Collar",
      "Depth",
      "Sub Drill",
      "Azimuth",
      "Dip",
      "Tampao",
      "Carga"
    ],
    "pitdev_consolidated": [
      "ID",
      "Y",
      "X",
      "Z",
      "Diâmetro",
      "Azimute",
      "Ângulo planejado",
      "Ângulo do talude"
    ]
  },
  "pitdev": {
    "plan_columns": {
      "id": ["ID"],
      "diameter": ["Diameter", "Diâmetro"],
      "azimuth": ["Azimuth", "Azimute"],
      "angle": ["Angulo", "Ângulo", "Dip", "Inclination", "Inclinação"]
    },
    "angle_reference_degrees": 90
  },
  "matching": {
    "prefix_priority": [
      "L-",
      "E-",
      "L_"
    ],
    "strip_prefixes": [
      "L-",
      "E-",
      "L_"
    ],
    "prefer_first_within_same_prefix": true
  },
  "validation": {
    "allow_empty_rows": true,
    "mvv_required_row_columns": [
      "ID",
      "Type",
      "Descricao",
      "Diameter",
      "X Collar",
      "Y Collar",
      "X Toe",
      "Y Toe",
      "Z Toe",
      "Z Collar",
      "Depth",
      "Sub Drill",
      "Azimuth",
      "Dip"
    ],
    "mvv_plan_required_row_columns": [
      "ID"
    ],
    "mvv_numeric_fields": [
      "Diameter",
      "X Collar",
      "Y Collar",
      "X Toe",
      "Y Toe",
      "Z Toe",
      "Z Collar",
      "Depth",
      "Sub Drill",
      "Azimuth",
      "Dip"
    ],
    "mvv_plan_numeric_fields": [
      "Diameter",
      "X Collar",
      "Y Collar",
      "Z Collar",
      "Depth",
      "Sub Drill",
      "Azimuth",
      "Dip",
      "Tampao",
      "Carga"
    ],
    "rd_numeric_fields": [
      "Y_RD",
      "X_RD",
      "Z_RD"
    ],
    "pitdev_field_numeric_fields": ["Y", "X", "Z"],
    "pitdev_plan_numeric_fields": ["diameter", "azimuth", "angle"],
    "fail_on_missing_mvv_rows": true,
    "fail_on_missing_mvv_columns": true,
    "fail_on_bad_rd_rows": true,
    "fail_on_unparseable_coordinates": true,
    "fail_on_invalid_prefix": true
  },
  "formatting": {
    "font_name": "Arial",
    "header_fill": "D9EAF7",
    "final_fill": "E2F0D9",
    "section_fill": "FFF2CC",
    "numeric_format": "0.000",
    "profundidade_final_format": "0.00",
    "freeze_panes": "A2",
    "min_width": 10,
    "max_width": 36,
    "highlight_final_columns": [
      "ID_FINAL",
      "Y_FINAL",
      "X_FINAL",
      "Z_COLLAR_FINAL",
      "PROFUNDIDADE_FINAL"
    ],
    "numeric_headers": [
      "Diameter",
      "X Collar",
      "Y Collar",
      "X Toe",
      "Y Toe",
      "Z Toe",
      "Z Collar",
      "Depth",
      "Sub Drill",
      "Azimuth",
      "Dip",
      "Y",
      "X",
      "Z",
      "Profundidade",
      "Tampao",
      "Carga",
      "Y_RD",
      "X_RD",
      "Z_RD",
      "Y_FINAL",
      "X_FINAL",
      "Z_COLLAR_FINAL",
      "PROFUNDIDADE_FINAL",
      "Diâmetro",
      "Azimute",
      "Ângulo planejado",
      "Ângulo do talude"
    ]
  },
  "output": {
    "file_name": "MVV_RD_CONSOLIDADO_FINAL.xlsx",
    "mvv_plan_file_name": "MVV_PLANO_PERFURACAO_ORGANIZADO.xlsx",
    "rd_only_file_name": "RD_EXECUTADO_ORGANIZADO.xlsx",
    "pitdev_file_name": "CONSOLIDACAO_PROJETO_O-PITDEV.xlsx",
    "sheets": {
      "consolidated": "CONSOLIDADO_FINAL",
      "rd_treated": "RD_TRATADA",
      "log": "LOG_VALIDACAO",
      "mvv_plan": "PLANO_MVV",
      "executed": "RD_EXECUTADO",
      "pitdev_consolidated": "CONSOLIDACAO_O-PITDEV",
      "pitdev_log": "LOG_O-PITDEV"
    },
    "labels": {
      "mvv_count": "Quantidade de furos na MVV",
      "rd_raw_count": "Quantidade de registros na RD original",
      "rd_unique_count": "Quantidade de furos unicos na RD tratada",
      "rd_matched_count": "Quantidade de furos com dado RD encontrado",
      "rd_missing_count": "Quantidade de furos sem dado RD",
      "dual_prefix_count": "Quantidade de casos com L_ e E- para o mesmo furo",
      "missing_title": "Furos sem correspondencia na RD",
      "rd_only_title": "Furos na RD sem correspondencia na MVV",
      "pitdev_field_count": "Linhas do levantamento de campo",
      "pitdev_matched_count": "Linhas consolidadas",
      "pitdev_field_without_plan_count": "IDs do campo sem plano",
      "pitdev_plan_without_field_count": "Furos do plano sem levantamento",
      "pitdev_field_without_plan_title": "IDs do campo sem correspondencia no plano",
      "pitdev_plan_without_field_title": "Furos do plano sem correspondencia no campo"
    }
  },
